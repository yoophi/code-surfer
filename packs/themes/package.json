{
  "name": "@code-surfer/themes",
  "description": "Themes for Code Surfer",
  "version": "3.1.1",
  "private": false,
  "license": "MIT",
  "author": "pomber",
  "repository": "pomber/code-surfer",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=8",
    "npm": ">=5"
  },
  "scripts": {
    "start": "tsup src/index.ts --format cjs,esm --dts --sourcemap --external react --external theme-ui --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap --external react --external theme-ui --clean",
    "test": "vitest run --globals --environment jsdom",
    "test:watch": "vitest --globals --environment jsdom"
  },
  "peerDependencies": {
    "@emotion/react": ">=11.1.1",
    "react": "^18.0.0 || ^19.0.0",
    "theme-ui": "^0.17.4"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "theme-ui": "^0.17.4",
    "tslib": "^2.8.1"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/**/?(*.)(spec|test).(ts|js)?(x)"
    ]
  }
}
