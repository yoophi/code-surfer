{
  "name": "code-surfer",
  "description": "Rad code slides",
  "version": "3.1.1",
  "license": "MIT",
  "author": "pomber",
  "repository": "pomber/code-surfer",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=8",
    "npm": ">=5"
  },
  "scripts": {
    "start": "tsup src/index.ts --format cjs,esm --dts --sourcemap --external react --external mdx-deck --external theme-ui --external @emotion/react --external @code-surfer/standalone --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap --external react --external mdx-deck --external theme-ui --external @emotion/react --external @code-surfer/standalone --clean",
    "test": "vitest run --globals --environment jsdom",
    "test:watch": "vitest --globals --environment jsdom"
  },
  "peerDependencies": {
    "mdx-deck": "^3.0.10 || ^4.1.1",
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@code-surfer/standalone": "workspace:*",
    "@emotion/react": "^11.14.0",
    "array.prototype.flat": "^1.3.3",
    "diff": "^8.0.2",
    "prismjs": "^1.30.0",
    "rebound": "^0.1.0",
    "react-swipeable": "^7.0.2",
    "shell-quote": "^1.8.3",
    "theme-ui": "^0.17.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/prismjs": "^1.26.6",
    "mdx-deck": "^4.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tslib": "^2.8.1"
  },
  "keywords": [
    "mdx",
    "mdx-deck",
    "slides",
    "react",
    "code",
    "highlight",
    "token",
    "prism",
    "animation",
    "transition",
    "reactjs"
  ],
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/code-surfer"
  }
}
