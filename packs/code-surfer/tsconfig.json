{
  "include": ["src"],
  "compilerOptions": {
    "target": "es2019",
    "module": "esnext",
    "lib": ["dom", "esnext"],
    "allowJs": true,
    "declaration": false,
    "strictNullChecks": false,
    "importHelpers": true,
    "sourceMap": true,
    "rootDir": "./src",
    "strict": false,
    "noImplicitAny": false,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "baseUrl": "./",
    "paths": {
      "*": ["src/*", "node_modules/*"]
    },
    "jsx": "react",
    "esModuleInterop": true
  }
}

