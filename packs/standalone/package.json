{
  "name": "@code-surfer/standalone",
  "description": "Code Surfer React component",
  "version": "3.1.1",
  "private": false,
  "license": "MIT",
  "author": "pomber",
  "repository": "pomber/code-surfer",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=8",
    "npm": ">=5"
  },
  "scripts": {
    "start": "tsup src/index.tsx --format cjs,esm --dts --sourcemap --external react --external @code-surfer/step-parser --external @code-surfer/themes --watch",
    "build": "tsup src/index.tsx --format cjs,esm --dts --sourcemap --external react --external @code-surfer/step-parser --external @code-surfer/themes --clean",
    "test": "vitest run --globals --environment jsdom",
    "test:watch": "vitest --globals --environment jsdom"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@code-surfer/step-parser": "workspace:*",
    "@code-surfer/themes": "workspace:*",
    "array.prototype.flat": "^1.3.3",
    "diff": "^8.0.2",
    "prismjs": "^1.30.0",
    "rebound": "^0.1.0",
    "shell-quote": "^1.8.3"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/table": "^6.3.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "table": "^6.9.0",
    "tslib": "^2.8.1"
  },
  "keywords": [
    "mdx",
    "mdx-deck",
    "slides",
    "react",
    "code",
    "highlight",
    "token",
    "prism",
    "animation",
    "transition",
    "reactjs"
  ],
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/code-surfer"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/**/?(*.)(spec|test).(ts|js)?(x)"
    ]
  }
}
