{
  "name": "@code-surfer/step-parser",
  "version": "3.1.1",
  "private": false,
  "license": "MIT",
  "author": "pomber",
  "repository": "pomber/code-surfer",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=8",
    "npm": ">=5"
  },
  "scripts": {
    "start": "tsup src/index.ts --format cjs,esm --dts --sourcemap --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap --clean",
    "test": "vitest run --globals",
    "test:watch": "vitest --globals"
  },
  "dependencies": {
    "array.prototype.flat": "^1.3.3",
    "diff": "^8.0.2",
    "prismjs": "^1.30.0",
    "shell-quote": "^1.8.3"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/prismjs": "^1.26.6",
    "tslib": "^2.8.1"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/**/?(*.)(spec|test).(ts|js)?(x)"
    ]
  }
}
