---
import CodeSurferPreview from "../components/CodeSurferPreview.jsx";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Code Surfer - React code slides</title>
    <meta
      name="description"
      content="Code Surfer turns code into animated React slide experiences."
    />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">React 19 ready</p>
          <h1>Code Surfer</h1>
          <p class="lede">
            Build animated code slides with focused lines, smooth code morphing,
            scrolling, zooming, themes, and line numbers.
          </p>
          <div class="actions">
            <a href="#usage">Use it</a>
            <a href="#api" class="secondary">API</a>
          </div>
        </div>
        <CodeSurferPreview client:load />
      </section>

      <section id="usage" class="content">
        <h2>Use Code Surfer in React</h2>
        <p>
          The modern package path is the standalone React component. It does not
          require Gatsby or MDX Deck.
        </p>
        <pre><code>{`import { CodeSurfer } from "@code-surfer/standalone";

const steps = [
  {
    code: "console.log(1);\\nconsole.log(2);",
    lang: "js"
  },
  {
    code: "console.log(1);\\nconsole.log(2);",
    focus: "2",
    subtitle: "Focus the second line"
  }
];

export function Slide({ progress }) {
  return <CodeSurfer steps={steps} progress={progress} />;
}`}</code></pre>
      </section>

      <section class="grid">
        <article>
          <h2>Focus</h2>
          <p>
            Use focus strings like <code>1:2,3[8:10]</code> to highlight lines
            and columns.
          </p>
        </article>
        <article>
          <h2>Steps</h2>
          <p>
            Provide multiple code snapshots and Code Surfer animates added,
            removed, and changed lines.
          </p>
        </article>
        <article>
          <h2>Themes</h2>
          <p>
            Pass themes from <code>@code-surfer/themes</code> or your own Theme
            UI-compatible style object.
          </p>
        </article>
        <article>
          <h2>Line Numbers</h2>
          <p>
            Set <code>showNumbers: true</code> on the first step to render line
            numbers through the whole slide.
          </p>
        </article>
      </section>

      <section id="api" class="content">
        <h2>Step shape</h2>
        <pre><code>{`type InputStep = {
  code: string;
  lang?: string;
  focus?: string;
  title?: string;
  subtitle?: string;
  showNumbers?: boolean;
};`}</code></pre>
        <p>
          Existing MDX Deck-specific wrappers remain in the legacy
          <code>code-surfer</code> package, but new docs and examples should use
          <code>@code-surfer/standalone</code>.
        </p>
      </section>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(body) {
    margin: 0;
    background: #f4f0e8;
    color: #1d1b18;
    font-family: ui-serif, Georgia, Cambria, "Times New Roman", serif;
  }

  :global(code),
  :global(pre),
  :global(button),
  :global(input) {
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  }

  .page {
    min-height: 100vh;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(280px, 0.85fr) minmax(420px, 1.15fr);
    gap: 48px;
    min-height: 88vh;
    padding: 64px min(7vw, 96px) 44px;
    align-items: center;
    border-bottom: 1px solid #d8d0c1;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: #7b3f2d;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(60px, 10vw, 132px);
    line-height: 0.86;
    letter-spacing: 0;
  }

  .lede {
    max-width: 560px;
    margin: 28px 0 0;
    font-size: 23px;
    line-height: 1.35;
  }

  .actions {
    display: flex;
    gap: 12px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 18px;
    border: 1px solid #1d1b18;
    background: #1d1b18;
    color: #fffaf0;
    text-decoration: none;
    font-weight: 700;
  }

  .actions a.secondary {
    background: transparent;
    color: #1d1b18;
  }

  :global(.preview-shell) {
    border: 1px solid #1d1b18;
    background: #17171c;
    box-shadow: 12px 12px 0 #c96c39;
    min-width: 0;
  }

  :global(.preview-toolbar) {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    background: #23232b;
  }

  :global(.preview-tabs),
  :global(.preview-step) {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  :global(.preview-toolbar button) {
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: transparent;
    color: #f7efe1;
    min-height: 32px;
    padding: 0 12px;
    cursor: pointer;
  }

  :global(.preview-toolbar button.is-active) {
    background: #f7efe1;
    color: #17171c;
  }

  :global(.preview-step span) {
    color: #f7efe1;
    min-width: 52px;
    text-align: center;
    font-size: 13px;
  }

  :global(.preview-stage) {
    height: 410px;
    width: 100%;
  }

  :global(.preview-range) {
    width: calc(100% - 24px);
    margin: 12px;
  }

  .content,
  .grid {
    width: min(1040px, calc(100vw - 40px));
    margin: 0 auto;
    padding: 72px 0;
  }

  .content {
    max-width: 840px;
  }

  h2 {
    margin: 0 0 14px;
    font-size: 34px;
    letter-spacing: 0;
  }

  p {
    font-size: 18px;
    line-height: 1.65;
  }

  pre {
    overflow: auto;
    padding: 22px;
    background: #1d1b18;
    color: #fff7e6;
    border-radius: 0;
    font-size: 14px;
    line-height: 1.55;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  article {
    border-top: 3px solid #1d1b18;
    padding-top: 18px;
  }

  article h2 {
    font-size: 24px;
  }

  article p {
    font-size: 16px;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 44px 20px 40px;
      min-height: auto;
    }

    .grid {
      grid-template-columns: 1fr 1fr;
    }

    :global(.preview-stage) {
      height: 320px;
    }
  }

  @media (max-width: 560px) {
    h1 {
      font-size: 64px;
    }

    .lede {
      font-size: 19px;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    :global(.preview-toolbar) {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
