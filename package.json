{
  "private": true,
  "packageManager": "pnpm@9.10.0",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@storybook/react-vite": "^10.3.5",
    "execa": "^2.0.1",
    "fs-extra": "^8.1.0",
    "jsdom": "^29.1.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "1.18.2",
    "pretty-quick": "1.11.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.0.2",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "format": "prettier --ignore-path .prettierignore --write '**/*.{js,jsx,css,md,mdx}'",
    "format:check": "prettier --ignore-path .prettierignore --check '**/*.{js,jsx,css,md,mdx}'",
    "build:step-parser": "pnpm --filter @code-surfer/step-parser build",
    "build:themes": "pnpm --filter @code-surfer/themes build",
    "build:standalone": "pnpm --filter @code-surfer/standalone build",
    "build:codesurfer": "pnpm --filter code-surfer build",
    "build:sites": "node sites/build",
    "prepare": "run-s build:step-parser build:themes build:standalone build:codesurfer",
    "predeploy": "run-s prepare build:sites",
    "test:step-parser": "pnpm --filter @code-surfer/step-parser test",
    "test:themes": "pnpm --filter @code-surfer/themes test",
    "test:standalone": "pnpm --filter @code-surfer/standalone test",
    "test:codesurfer": "pnpm --filter code-surfer test",
    "test": "run-p format:check test:step-parser test:themes test:standalone test:codesurfer"
  }
}
